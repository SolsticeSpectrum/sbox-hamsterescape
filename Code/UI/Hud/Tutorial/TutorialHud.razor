@namespace Sandbox
@inherits PanelComponent

<root>
	<div class="tutorial">
		<p>@LocalizedStepText(tutorial)</p>
		<div class="progress-bar" style="display: @( Visible ? "flex" : "none" )">
			<div class="progress" style="width: @bar"></div>
		</div>
	</div>
</root>

@code
{
	public static TutorialHud Instance { get; private set; }

	[Property] SceneManager SceneManager { get; set; }
	[Property] public int Progress { get; set; } = 500;

	private static readonly string[] keys = new[]
	{
		"tutorial.move_mouse",
		"tutorial.wsad",
		"tutorial.drag_lmb",
		"tutorial.eq",
		"tutorial.reset",
		"tutorial.collect_gold",
		"tutorial.reach_goal",
		"tutorial.max_points"
	};

	private static readonly string[] actions = new[]
	{
		"Tilt Forward", "Tilt Backward", "Tilt Left", "Tilt Right",
		"Spin Button", "Spin Left", "Spin Right", "Rotation Reset"
	};

	public TimeSince TimeSince { get; set; } = 0;
	public bool Visible { get; set; } = true;

	private float bar = 0;
	private float increment = .5f;
	private long gold = 0;
	private int wins = 0;
	private int tutorial = 1;
	private bool first = false;
	private float cooldown = 2f;
	private TimeSince last = 0;

	protected override int BuildHash()
	{
		return System.HashCode.Combine( bar, tutorial, L.CurrentCode, InputBindings.Version );
	}

	protected override void OnAwake()
	{
		Instance = this;
		if ( Tutorial.IsFinished ) Enabled = false;
	}

	public void Restart()
	{
		tutorial = 1;
		bar = 0;
		first = false;
		last = 0;
		Visible = true;
		TimeSince = 0;
		gold = SceneManager.Golds;
		wins = SceneManager.Wins;
		Enabled = true;
	}

	protected override void OnUpdate()
	{
		Step();

		gold = SceneManager.Golds;
		wins = SceneManager.Wins;
	}

	private string LocalizedStepText( int step )
	{
		var key = keys[step - 1];
		return L.T( key, L.Keys( actions ) );
	}

	private void Controls()
	{
		bool condition = tutorial switch
		{
			1 => Input.MouseDelta != Vector2.Zero,
			2 => Input.Down( "Tilt Forward" )
				|| Input.Down( "Tilt Backward" )
				|| Input.Down( "Tilt Left" )
				|| Input.Down( "Tilt Right" ),
			3 => Input.MouseDelta != Vector2.Zero && Input.Down( "Spin Button" ),
			4 => Input.Down( "Spin Left" ) || Input.Down( "Spin Right" ),
			_ => false
		};

		if ( condition ) { bar += increment; Next(); }
	}

	private void Goal( bool goal )
	{
		if ( goal ? ( wins != SceneManager.Wins ) : ( gold != SceneManager.Golds ) )
			bar += Progress / ( goal ? 2 : 4 );

		Next();
	}

	private void Reset( bool reset )
	{
		if ( !reset && Input.Pressed( "Rotation Reset" ) && last > cooldown )
		{
			last = 0;

			if ( !first )
			{
				bar += Progress / 2;
				first = true;
			}
			else
			{
				bar += Progress / 2;
				first = false;

				Next();
			}
		}
	}

	private void Finish()
	{
		if ( TimeSince > 5 )
		{
			Tutorial.Finish();
			Enabled = false;
		}
	}

	private void Next()
	{
		if ( bar >= Progress )
		{
			tutorial++;
			bar = 0f;

			if ( tutorial == 8 ) { TimeSince = 0; Visible = !Visible; }
		}
	}

	private void Step()
	{
		switch ( tutorial )
		{
			case ( >= 1 ) and ( <= 4 ):
				Controls();
				break;
			case 5:
				Reset( false );
				break;
			case 6:
				Reset( true );
				Goal( false );
				break;
			case 7:
				Goal( true );
				break;
			case 8:
				Finish();
				break;
		}
	}
}
